{
	"name": "obsidian-plugin-template",
	"version": "0.0.1",
	"description": "Scaffold for Obsidian plugins. Fork and replace names, then implement your features.",
	"main": "main.js",
	"scripts": {
		"setup": "node onboard.mjs",
		"setup:check": "node onboard.mjs --check",
		"dev": "node esbuild.config.mjs",
		"type": "tsc -noEmit --skipLibCheck",
		"check": "pnpm type && pnpm lint && pnpm build",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"release": "bash release.sh",
		"version": "node version-bump.mjs && git add manifest.json versions.json README.md",
		"lint": "eslint main.ts ./src/",
		"lint:fix": "eslint main.ts ./src/ --fix"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"plugin"
	],
	"author": "imaikosuke",
	"authorUrl": "https://github.com/imaikosuke",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"esbuild": "0.28.0",
		"eslint": "^9.39.1",
		"eslint-plugin-obsidianmd": "^0.2.4",
		"obsidian": "^1.12.3",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
